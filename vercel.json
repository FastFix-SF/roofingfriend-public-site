{
  "rewrites": [
    { "source": "/admin",                      "destination": "https://fastfix-crm-westpeak.vercel.app/admin" },
    { "source": "/admin/:path*",               "destination": "https://fastfix-crm-westpeak.vercel.app/admin/:path*" },
    { "source": "/admin-login",                "destination": "https://fastfix-crm-westpeak.vercel.app/admin-login" },
    { "source": "/auth",                       "destination": "https://fastfix-crm-westpeak.vercel.app/admin-login" },
    { "source": "/mobile",                     "destination": "https://fastfix-crm-westpeak.vercel.app/mobile" },
    { "source": "/mobile/:path*",              "destination": "https://fastfix-crm-westpeak.vercel.app/mobile/:path*" },
    { "source": "/portal",                     "destination": "https://fastfix-crm-westpeak.vercel.app/portal" },
    { "source": "/portal/:path*",              "destination": "https://fastfix-crm-westpeak.vercel.app/portal/:path*" },
    { "source": "/workboard",                  "destination": "https://fastfix-crm-westpeak.vercel.app/workboard" },
    { "source": "/qbo-callback",               "destination": "https://fastfix-crm-westpeak.vercel.app/qbo-callback" },
    { "source": "/invoice/:id*",               "destination": "https://fastfix-crm-westpeak.vercel.app/invoice/:id*" },
    { "source": "/invoice-payment/:id*",       "destination": "https://fastfix-crm-westpeak.vercel.app/invoice-payment/:id*" },
    { "source": "/contract-signing/:token*",   "destination": "https://fastfix-crm-westpeak.vercel.app/contract-signing/:token*" },
    { "source": "/invite/:token*",             "destination": "https://fastfix-crm-westpeak.vercel.app/invite/:token*" },
    { "source": "/team/invite/:token*",        "destination": "https://fastfix-crm-westpeak.vercel.app/team/invite/:token*" },
    { "source": "/project-invite/:token*",     "destination": "https://fastfix-crm-westpeak.vercel.app/project-invite/:token*" },
    { "source": "/client-portal/:slug*",       "destination": "https://fastfix-crm-westpeak.vercel.app/client-portal/:slug*" },
    { "source": "/customer-dashboard",         "destination": "https://fastfix-crm-westpeak.vercel.app/customer-dashboard" },
    { "source": "/((?!admin|mobile|portal|admin-login|auth|workboard|qbo-callback|invoice|invoice-payment|contract-signing|invite|team|project-invite|client-portal|customer-dashboard|assets).*)", "destination": "/index.html" }
  ]
}
